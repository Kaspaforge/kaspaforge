{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaspaforge.org/schema/line-package-v1.schema.json",
  "title": "Kaspa Forge covenant line package (v1)",
  "description": "A secret-free package produced online and verified against a recovery record before offline signing.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema_version", "network", "product", "deal_id", "lines"],
  "properties": {
    "schema": { "const": "kaspa-forge-line-package" },
    "schema_version": { "const": 1 },
    "network": { "enum": ["mainnet", "testnet", "simnet"] },
    "product": { "enum": ["escrow", "deposit"] },
    "deal_id": { "type": "integer", "minimum": 0 },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mode", "outpoint", "amount", "covenant_id", "daa"],
        "properties": {
          "mode": { "type": "integer", "enum": [0, 1] },
          "outpoint": { "type": "string", "pattern": "^[0-9a-f]{64}:[0-9]+$" },
          "amount": { "type": "integer", "minimum": 1 },
          "covenant_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "daa": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
